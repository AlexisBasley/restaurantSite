---
import '../styles/global.css';
import { getEntry } from 'astro:content';

const site = await getEntry('config', 'site');
const { nom, description } = site.data;

interface Props {
  titre?: string;
}
const { titre } = Astro.props;
const titrePage = titre ? `${titre} · ${nom}` : `${nom} — ${description}`;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{titrePage}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Poppins:wght@600;700;800&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot />
  </body>
</html>
