---
import { getEntry } from 'astro:content';
import { Image } from 'astro:assets';
const site = await getEntry('config', 'site');
const { nom, slogan, description, heroImage, commandeUrl } = site.data;
---

<section id="accueil" class="hero">
  {
    heroImage && (
      <Image src={heroImage} alt={nom} class="hero-bg" widths={[768, 1280, 1920]} sizes="100vw" />
    )
  }
  <div class="hero-overlay"></div>
  <div class="contenu hero-contenu">
    <p class="hero-kicker">🍔 Fait maison · Sur place ou à emporter</p>
    <h1 class="hero-titre">{nom}</h1>
    <p class="hero-slogan">{slogan}</p>
    <p class="hero-desc">{description}</p>
    <div class="hero-actions">
      {
        commandeUrl && (
          <a href={commandeUrl} target="_blank" rel="noopener" class="bouton bouton-commander">
            🛵 Commander sur Uber Eats
          </a>
        )
      }
      <a href="#menu" class="bouton">Voir le menu</a>
      <a href="#infos" class="bouton bouton-secondaire">Nous trouver</a>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 80vh;
    display: flex;
    align-items: center;
    color: var(--blanc);
    background: linear-gradient(135deg, var(--rouge) 0%, var(--orange) 100%);
    overflow: hidden;
  }
  .hero-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      105deg,
      rgba(26, 20, 19, 0.78) 0%,
      rgba(26, 20, 19, 0.35) 70%,
      rgba(26, 20, 19, 0.15) 100%
    );
  }
  .hero-contenu {
    position: relative;
    padding-top: 4rem;
    padding-bottom: 4rem;
    max-width: 680px;
  }
  .hero-kicker {
    display: inline-block;
    background: rgba(255, 255, 255, 0.15);
    border: 1px solid rgba(255, 255, 255, 0.3);
    padding: 0.4rem 1rem;
    border-radius: 999px;
    font-weight: 600;
    font-size: 0.9rem;
    margin-bottom: 1.2rem;
  }
  .hero-titre {
    font-size: clamp(2.6rem, 7vw, 4.5rem);
    margin-bottom: 0.6rem;
    text-shadow: 0 2px 20px rgba(0, 0, 0, 0.3);
  }
  .hero-slogan {
    font-size: clamp(1.2rem, 3vw, 1.6rem);
    font-weight: 600;
    color: var(--jaune);
    margin-bottom: 1rem;
  }
  .hero-desc {
    font-size: 1.05rem;
    max-width: 520px;
    margin-bottom: 2rem;
    opacity: 0.95;
  }
  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .bouton-commander {
    background: #06c167;
  }
  .bouton-commander:hover {
    background: #05a857;
  }
</style>
