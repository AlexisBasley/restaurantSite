---
import { getEntry } from 'astro:content';
import { Image } from 'astro:assets';

const galerie = await getEntry('galerie', 'galerie');
const photos = galerie?.data.photos ?? [];
---

{
  photos.length > 0 && (
    <section id="galerie" class="section galerie">
      <div class="contenu">
        <h2 class="section-titre">En <span>images</span></h2>
        <p class="section-soustitre">Un aperçu de la maison</p>
        <div class="grille">
          {photos.map((p) => (
            <figure class="photo">
              <Image src={p.image} alt={p.legende || 'Photo du restaurant'} widths={[400, 800]} sizes="(max-width: 600px) 50vw, 350px" />
              {p.legende && <figcaption>{p.legende}</figcaption>}
            </figure>
          ))}
        </div>
      </div>
    </section>
  )
}

<style>
  .galerie {
    background: var(--blanc);
  }
  .grille {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 1rem;
  }
  .photo {
    position: relative;
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: var(--ombre);
  }
  .photo :global(img) {
    width: 100%;
    height: 240px;
    object-fit: cover;
    transition: transform 0.3s ease;
  }
  .photo:hover :global(img) {
    transform: scale(1.05);
  }
  .photo figcaption {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    background: linear-gradient(transparent, rgba(0, 0, 0, 0.7));
    color: var(--blanc);
    padding: 1.5rem 1rem 0.75rem;
    font-size: 0.9rem;
    font-weight: 600;
  }
</style>
